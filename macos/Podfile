platform :osx, '11.0'

# CocoaPods analytics sends network stats synchronously affecting build performance.
ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

# This is the boilerplate that Flutter needs in the Podfile
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/\s*FLUTTER_ROOT\s*=\s*(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run flutter pub get"
end

# Ensure you have the Flutter framework in your project
generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
if File.exist?(generated_xcode_build_settings_path)
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/\s*FLUTTER_FRAMEWORK_DIR\s*=\s*(.*)/)
    @flutter_framework_dir = matches[1].strip if matches
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Install pods for all Flutter plugins
  # On macOS, the plugins are sub-projects of the Runner project
  pod_install_path = File.join('..', 'Flutter', 'ephemeral', '.symlinks', 'plugins')
  if File.exist?(pod_install_path)
    Dir.foreach(pod_install_path) do |plugin_name|
      next if plugin_name == '.' or plugin_name == '..'
      plugin_podspec = File.join(pod_install_path, plugin_name, 'macos', "#{plugin_name}.podspec")
      if File.exist?(plugin_podspec)
        pod plugin_name, :path => File.join(pod_install_path, plugin_name, 'macos')
      end
    end
  end

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '11.0'
    end
  end
end
